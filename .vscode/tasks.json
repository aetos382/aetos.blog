{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hugo: Server",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(ERROR|WARN)\\s+(.*)$",
          "severity": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Start building sites",
          "endsPattern": "^Web Server is available"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Hugo: Build",
      "type": "npm",
      "script": "build",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(ERROR|WARN)\\s+(.*)$",
          "severity": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": false,
          "beginsPattern": "^Start building sites",
          "endsPattern": "^Total in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Hugo: Build (production)",
      "type": "npm",
      "script": "build:prod",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(ERROR|WARN)\\s+(.*)$",
          "severity": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": false,
          "beginsPattern": "^Start building sites",
          "endsPattern": "^Total in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}

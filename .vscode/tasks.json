{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hugo: Server",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Hugo: Build",
      "type": "npm",
      "script": "build",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Hugo: Build (production)",
      "type": "npm",
      "script": "build:prod",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
